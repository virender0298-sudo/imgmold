---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import { locales, localeKeys, defaultLocale } from '../i18n/config';
import { t, getLocalizedPath, getLocaleConfig } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  jsonLd?: Record<string, any>;
  locale?: string;
}

const {
  title = "IMGMOLD.COM - Premium Local Photo Compressor & Preset Resizer",
  description = "Compress and resize passport photos, signatures, and document photos for UPSC, SSC, and official government exam forms locally in your browser. 100% secure, zero data transfer.",
  canonicalUrl = Astro.url.href,
  ogImage = "/og-image.jpg",
  jsonLd,
  locale = defaultLocale
} = Astro.props;

const localeConfig = getLocaleConfig(locale);
const currentPath = Astro.url.pathname.replace(`/${locale}`, '') || '/';

// Default structured data for the resizer utility app
const defaultJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "ImgMold.com Local Resizer",
  "operatingSystem": "All",
  "applicationCategory": "UtilityApplication",
  "offers": {
    "@type": "Offer",
    "price": "0.00",
    "priceCurrency": "USD"
  },
  "description": "Secure local-first passport photo resizer and signature compressor for UPSC, SSC and official government applications."
};

const finalJsonLd = jsonLd || defaultJsonLd;
---

<!doctype html>
<html lang={locale} dir={localeConfig.dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="ImgMold" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- PWA & Mobile Optimization -->
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="IMGMOLD" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang Tags for SEO -->
    {localeKeys.map((lang) => (
      <link rel="alternate" hreflang={lang} href={`${Astro.site || ''}${getLocalizedPath(lang, currentPath)}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${Astro.site || ''}${currentPath}`} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Inline script to prevent theme flash -->
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>

    <!-- Structured Data JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(finalJsonLd)} />

    <!-- Global site tag (gtag.js) - Google Analytics Placeholder -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>

    <!-- Google AdSense Placeholder -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX" crossorigin="anonymous"></script>
  </head>
  <body class="bg-[#f5f5f7] text-[#1d1d1f] dark:bg-[#000000] dark:text-[#ffffff] font-sans antialiased min-h-screen flex flex-col transition-colors duration-200">
    
    <!-- Premium Apple-Style Sticky Navigation Header -->
    <header class="sticky top-0 z-40 w-full bg-[#f5f5f7]/80 dark:bg-[#000000]/80 backdrop-blur-md border-b border-[#e0e0e0] dark:border-[#222222] transition-colors duration-200">
      <div class="max-w-6xl mx-auto px-6 h-12 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
          <svg className="w-5 h-5 text-[#0066cc] dark:text-[#2997ff]" fill="none" stroke="currentColor" strokeWidth="2.5" viewBox="0 0 24 24">
            <path strokeLinecap="round" strokeLinejoin="round" d="M3.75 3.75v16.5h16.5M7.5 12h9m-9-3.75h9m-9 7.5h9" />
          </svg>
          <span class="font-extrabold text-sm uppercase tracking-wider font-display">IMGMOLD</span>
        </a>

        <nav class="flex items-center gap-3 md:gap-6">
          <a href="/about" class="hidden md:block text-[13px] font-medium text-[#7a7a7a] hover:text-[#1d1d1f] dark:text-[#cccccc] dark:hover:text-white transition-colors duration-200">About</a>
          <a href="/privacy" class="hidden md:block text-[13px] font-medium text-[#7a7a7a] hover:text-[#1d1d1f] dark:text-[#cccccc] dark:hover:text-white transition-colors duration-200">Privacy</a>
          <a href="/terms" class="hidden md:block text-[13px] font-medium text-[#7a7a7a] hover:text-[#1d1d1f] dark:text-[#cccccc] dark:hover:text-white transition-colors duration-200">Terms</a>
          <a href="/contact" class="hidden md:block text-[13px] font-medium text-[#7a7a7a] hover:text-[#1d1d1f] dark:text-[#cccccc] dark:hover:text-white transition-colors duration-200">Contact</a>
          <div class="hidden md:block h-4 w-px bg-[#e0e0e0] dark:bg-[#333333]"></div>
          
          <!-- Language Switcher -->
          <div class="relative" id="lang-switcher">
            <button id="lang-btn" class="flex items-center gap-1 text-[13px] font-medium text-[#7a7a7a] hover:text-[#1d1d1f] dark:text-[#cccccc] dark:hover:text-white transition-colors duration-200 cursor-pointer">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" /></svg>
              <span class="hidden md:inline">{localeConfig.name}</span>
              <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div id="lang-dropdown" class="hidden absolute right-0 top-full mt-2 w-44 bg-white dark:bg-[#1c1c1e] border border-[#e0e0e0] dark:border-[#333333] rounded-2xl shadow-[0_8px_30px_rgba(0,0,0,0.12)] dark:shadow-[0_8px_30px_rgba(0,0,0,0.4)] overflow-hidden z-50">
              {localeKeys.map((lang) => (
                <a
                  href={getLocalizedPath(lang, currentPath)}
                  class={`flex items-center px-4 py-2.5 text-[13px] transition-colors duration-150 ${
                    lang === locale
                      ? 'bg-[#0066cc]/10 text-[#0066cc] dark:text-[#2997ff] font-semibold'
                      : 'text-[#424245] dark:text-[#cccccc] hover:bg-[#f5f5f7] dark:hover:bg-[#2a2a2c]'
                  }`}
                >
                  <span class="mr-2 text-base leading-none">{locales[lang].flag}</span>
                  {locales[lang].name}
                  <span class="text-[11px] text-[#7a7a7a] dark:text-[#888] ml-1">({locales[lang].nameEn})</span>
                </a>
              ))}
            </div>
          </div>
          
          <ThemeToggle />
        </nav>
      </div>
    </header>

    <!-- Main Content wrapper -->
    <main class="flex-grow flex flex-col justify-start">
      <slot />
    </main>

    <!-- Premium Minimalist Footer -->
    <footer class="w-full bg-[#f5f5f7] dark:bg-[#1a1a1c] border-t border-[#e0e0e0] dark:border-[#222222] transition-colors duration-200 py-10 mt-auto">
      <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-8 items-center text-center md:text-left">
        <div>
          <p class="text-xs text-[#7a7a7a] dark:text-[#cccccc] leading-relaxed">
            © {new Date().getFullYear()} IMGMOLD.COM. {t(locale, 'footer.rights')}
            <br />
            {t(locale, 'footer.localProcessing')}
          </p>
        </div>
        <div class="flex justify-center md:justify-end gap-5">
          <a href="/privacy" class="text-xs text-[#7a7a7a] hover:text-[#1d1d1f] dark:text-[#cccccc] dark:hover:text-white transition-colors duration-200">{t(locale, 'footer.privacyPolicy')}</a>
          <a href="/terms" class="text-xs text-[#7a7a7a] hover:text-[#1d1d1f] dark:text-[#cccccc] dark:hover:text-white transition-colors duration-200">{t(locale, 'footer.termsOfUse')}</a>
          <a href="/contact" class="text-xs text-[#7a7a7a] hover:text-[#1d1d1f] dark:text-[#cccccc] dark:hover:text-white transition-colors duration-200">{t(locale, 'footer.contactUs')}</a>
        </div>
      </div>
    </footer>

    <!-- Lenis Smooth Scrolling -->
    <script src="https://unpkg.com/@studio-freight/lenis@1.0.42/dist/lenis.min.js" is:inline></script>
    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        if (typeof Lenis !== 'undefined') {
          const lenis = new Lenis({
            duration: 1.2,
            easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), // https://www.desmos.com/calculator/brs54l4xou
            direction: 'vertical',
            gestureDirection: 'vertical',
            smooth: true,
            mouseMultiplier: 1,
            smoothTouch: false,
            touchMultiplier: 2,
            infinite: false,
          });

          function raf(time) {
            lenis.raf(time);
            requestAnimationFrame(raf);
          }

          requestAnimationFrame(raf);
        }
      });
    </script>
    
    <!-- Language Switcher Toggle -->
    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        const btn = document.getElementById('lang-btn');
        const dropdown = document.getElementById('lang-dropdown');
        if (btn && dropdown) {
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            dropdown.classList.toggle('hidden');
          });
          document.addEventListener('click', () => {
            dropdown.classList.add('hidden');
          });
        }
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
    --font-display: 'Outfit', 'Inter', system-ui, -apple-system, sans-serif;
  }
  body {
    font-family: var(--font-sans);
  }
  h1, h2, h3, h4, .font-display {
    font-family: var(--font-display);
  }
</style>
