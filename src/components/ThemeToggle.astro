---
<button id="theme-toggle" class="relative w-8 h-8 flex items-center justify-center rounded-full hover:bg-black/5 dark:hover:bg-white/10 transition-colors ml-2" aria-label="Toggle Dark Mode">
  <!-- Sun Icon (visible in dark mode) -->
  <svg id="theme-toggle-light-icon" class="hidden w-4 h-4 text-[#cccccc] hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
  </svg>
  <!-- Moon Icon (visible in light mode) -->
  <svg id="theme-toggle-dark-icon" class="hidden w-4 h-4 text-[#7a7a7a] hover:text-[#1d1d1f] transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
  </svg>
</button>

<script>
  // Astro runs this once when the component loads
  function setupThemeToggle() {
    const themeToggleDarkIcon = document.getElementById('theme-toggle-dark-icon');
    const themeToggleLightIcon = document.getElementById('theme-toggle-light-icon');
    const themeToggleBtn = document.getElementById('theme-toggle');

    if (!themeToggleBtn) return;

    // Check initial state from the document class applied by inline script in head
    if (document.documentElement.classList.contains('dark')) {
      themeToggleLightIcon?.classList.remove('hidden');
      themeToggleDarkIcon?.classList.add('hidden');
    } else {
      themeToggleDarkIcon?.classList.remove('hidden');
      themeToggleLightIcon?.classList.add('hidden');
    }

    // Add click event listener
    const handleToggle = () => {
      themeToggleDarkIcon?.classList.toggle('hidden');
      themeToggleLightIcon?.classList.toggle('hidden');

      if (document.documentElement.classList.contains('dark')) {
        document.documentElement.classList.remove('dark');
        localStorage.setItem('theme', 'light');
      } else {
        document.documentElement.classList.add('dark');
        localStorage.setItem('theme', 'dark');
      }
    };

    // Remove existing listener if any to avoid duplicates on navigation (ViewTransitions etc)
    themeToggleBtn.removeEventListener('click', handleToggle);
    themeToggleBtn.addEventListener('click', handleToggle);
  }

  // Run on initial load
  setupThemeToggle();
  
  // Run if using Astro ViewTransitions
  document.addEventListener('astro:page-load', setupThemeToggle);
</script>
