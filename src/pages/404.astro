---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found - IMGMOLD.COM" description="The page you are looking for does not exist. Back to local resizer tools.">
  <section class="max-w-md mx-auto text-center px-6 py-24 flex flex-col items-center justify-center flex-grow">
    <div class="w-16 h-16 rounded-full bg-[#f5f5f7] dark:bg-[#1a1a1c] flex items-center justify-center text-[#7a7a7a] dark:text-[#cccccc] mb-8 font-bold border border-[#e0e0e0] dark:border-[#333333]">
      404
    </div>
    
    <h1 class="text-3xl font-black tracking-tight text-[#1d1d1f] dark:text-white leading-tight mb-3">
      This page cannot be found.
    </h1>
    
    <p class="text-sm text-[#7a7a7a] dark:text-[#cccccc] mb-8 leading-relaxed">
      The link you followed may be broken, or the page has been moved. Use the local-first studio to start compressing your documents.
    </p>

    <a 
      href="/" 
      class="px-6 py-3 rounded-full bg-[#0066cc] dark:bg-[#2997ff] text-white font-semibold text-sm hover:opacity-95 shadow-sm transition-opacity duration-200"
    >
      Go to Local Studio
    </a>
  </section>
</Layout>
